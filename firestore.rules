/**
 * # Firestore Security Rules: MealGenius App
 *
 * Multi-plan, trust-based family app. Anyone signed in (anonymous auth is
 * sufficient) may read/write any /plans/{planId} tree. Plan IDs are
 * human-chosen slugs, so this is explicitly a low-trust model suitable
 * for a family/household.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- New multi-plan collections ---

    match /plans/{planId} {
      allow get, create, update: if isSignedIn();
      allow list: if false;
      allow delete: if false;
    }

    match /plans/{planId}/data/{docId} {
      allow read, write: if isSignedIn();
    }

    match /plans/{planId}/daily-meals/{dayId} {
      allow read, write: if isSignedIn();
    }

    // Single aggregate doc listing every plan so the landing picker can
    // render without enumerating the /plans collection.
    match /plans-index/{docId} {
      allow read, write: if isSignedIn();
    }

    // --- Legacy single-owner tree (kept read-only for rollback) ---

    function isAppOwnerPath(userId) {
      return userId == 'rP07763S2bNDtZcxoAaBnbyEvs92';
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isAppOwnerPath(userId);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /users/{userId}/data/{docId} {
      allow read: if isSignedIn() && isAppOwnerPath(userId);
      allow write: if false;
    }

    match /users/{userId}/daily-meals/{dayId} {
      allow read: if isSignedIn() && isAppOwnerPath(userId);
      allow write: if false;
    }
  }
}
